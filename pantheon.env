# OpenSkynet — Pantheon Edition
# Source this before launching: source pantheon.env

# Brain: Ollama via Cloudflare tunnel (zero cost)
export OPENAI_API_KEY=not-needed
export OPENAI_BASE_URL=https://naval-measures-mat-modern.trycloudflare.com/v1
export SEDIMAN_MODEL=llama3

# Data dir — Termux-safe path
export SEDIMAN_DATA_DIR=$HOME/.sediman-pantheon

# Stealth on by default
export SEDIMAN_STEALTH=true

# Telegram reporting
export TELEGRAM_BOT_TOKEN=8679655550:AAGUB1m5fmqHc8OHqqM24Vixz8FfwX-gqD4

# Memory / performance tuning for mobile
export SEDIMAN_MEMORY_LIMIT=1500
export SEDIMAN_MAX_RESULT_CHARS=1500
export SEDIMAN_COMPRESS_THRESHOLD=10
